# Rename this file to .env and fill in your credentials.
# Never commit .env to source control.

#DELTA_API_KEY=yhAUB0qB2z7snVRXkydV4Da4aJanMQ
#DELTA_API_SECRET=jO5H3yHOD4jGD1G8a7B1k1FtSM0T4aEC91oU2NfaMpNXhRMb2V4OFDjgaTPr
#DELTA_EXCHANGE_ENV=prod-india   # or prod-india
#DELTA_MODE=paper


# ─── EXCHANGE CREDENTIALS ───────────────────────────────────────
DELTA_API_KEY=yhAUB0qB2z7snVRXkydV4Da4aJanMQ
DELTA_API_SECRET=jO5H3yHOD4jGD1G8a7B1k1FtSM0T4aEC91oU2NfaMpNXhRMb2V4OFDjgaTPr

# ─── MODE & ENVIRONMENT ─────────────────────────────────────────
DELTA_MODE=live  #live or paper
DELTA_EXCHANGE_ENV=testnet-india  # 'testnet-india' (safe default) or 'prod-india'

# ─── LIVE TRADING SAFETY GATE ────────────────────────────────────
# Both DELTA_EXCHANGE_ENV=prod-india AND DELTA_ALLOW_LIVE_TRADING=true
# must be set simultaneously to send real orders.
# Removing either one will block startup and prevent live execution.
DELTA_ALLOW_LIVE_TRADING=true  # Set to true ONLY when intentionally trading live

# ─── STRATEGY ───────────────────────────────────────────────────
DELTA_STRATEGY_NAME=portfolio
DELTA_TRADE_SYMBOLS=["BTCUSD","ETHUSD","SOLUSD"]

# ─── RISK SETTINGS ──────────────────────────────────────────────
DELTA_ORDER_SIZE=100
DELTA_MAX_POSITIONS=3
DELTA_MAX_RISK_PER_TRADE=0.01
DELTA_MAX_DAILY_LOSS=0.05
DELTA_MAX_LEVERAGE=10.0
DELTA_MAX_ASSET_EXPOSURE=0.25

# ─── TIMING ─────────────────────────────────────────────────────
DELTA_TRADE_FREQUENCY_S=60

# ─── MONITORING ─────────────────────────────────────────────────
DELTA_METRICS_PORT=8000
DELTA_METRICS_ADDR=0.0.0.0
DELTA_DISABLE_METRICS_SERVER=false

# ─── DATABASE ───────────────────────────────────────────────────
DELTA_STATE_DB_PATH=state.db

# ─── SAFETY ─────────────────────────────────────────────────────
DELTA_ENABLE_RISK=true
DELTA_ENABLE_ADVANCED_RISK=true
DELTA_ENABLE_SMART_ORDER_ROUTING=true
DELTA_CANCEL_LEFTOVER_ORDERS_ON_STARTUP=true
DELTA_SHUTDOWN_SIGNAL_PATH=logs/bot.shutdown

# ─── WEBSOCKET ──────────────────────────────────────────────────
DELTA_WEBSOCKET_ENABLED=true
DELTA_WEBSOCKET_RECONNECT_INTERVAL_S=5
DELTA_WEBSOCKET_FALLBACK_POLL_INTERVAL_S=2

# ─── POSITION SYNC TUNING ────────────────────────────────────────
# Delta India exchange can take 3-10s to reflect a new position.
# 5 retries × 2.5 s gives ~12.5 s settling window before warning.
DELTA_POSITION_SYNC_RETRIES=5
DELTA_POSITION_SYNC_RETRY_DELAY_S=2.5
